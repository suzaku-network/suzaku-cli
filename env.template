# Operator L1 Opt-In contract address for local development
# Default: 0x8A791620dd6260079BF849Dc5567aDC3F2FdC318
#OP_L1_OPT_IN=

# Operator Vault Opt-In contract address for local development
# Default: 0xa513E6E4b8f2a923D98304ec87F64353C4D5C853
#OP_VAULT_OPT_IN=

# ==============================================================================
# CONTRACT ADDRESSES - MAINNET
# ==============================================================================

# L1 Registry contract address on Mainnet
# Default: 0xaA59b19A7636bf6d821aA124A14eEE6C92746110
#L1_REGISTRY_MAINNET=

# Operator Registry contract address on Mainnet
# Default: 0xCccb4eC6408bF2c9D057d63DAB01E55BB536936e
