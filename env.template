# ==============================================================================
# SUZAKU CLI - Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in the values as needed.
# All variables have sensible defaults unless otherwise specified.
# ==============================================================================

# ==============================================================================
# AUTHENTICATION
# ==============================================================================

# Private key for signing transactions (hex format with 0x prefix)
# Can also be provided via --private-key flag or --secret-name (pass) or --ledger
#PK=

# ==============================================================================
# SHELL
# ==============================================================================

# Shell to use for auto-completion setup (bash, zsh)
# Default: auto-detected from user's shell
#SHELL=

# ==============================================================================
# LOGGING
# ==============================================================================

# Log level for CLI output (DEBUG, INFO, WARN, ERROR)
# Default: INFO
LogLevel=INFO

# ==============================================================================
# LEDGER HARDWARE WALLET
# ==============================================================================

# Account index to use when connecting to Ledger hardware wallet
# Default: 0 (first account)
LEDGER_ACCOUNT_INDEX=0

# ==============================================================================
# SAFE MULTISIG
# ==============================================================================

# API key for Safe Transaction Service (required for mainnet Safe operations)
# Not required for Fuji testnet
#SAFE_API_KEY=

# ==============================================================================
# SIGNATURE AGGREGATOR
# ==============================================================================

# Custom URL for the Warp signature aggregator service
# Default (Fuji): https://glacier-api-dev.avax.network/v1/signatureAggregator/fuji/aggregateSignatures
# Default (Mainnet): https://glacier-api.avax.network/v1/signatureAggregator/mainnet/aggregateSignatures
#SIG_AGG_URL=

# ==============================================================================
# PASSWORD STORE (pass)
# ==============================================================================

# Custom directory for the password store
# Default: ~/.password-store
#PASSWORD_STORE_DIR=

# ==============================================================================
# CONTRACT ADDRESSES - FUJI TESTNET
# ==============================================================================

# L1 Registry contract address on Fuji
# Default: 0xB9826Bbf0deB10cC3924449B93F418db6b16be36
#L1_REGISTRY_FUJI=

# Operator Registry contract address on Fuji
# Default: 0x46D45D6be6214F6bd8124187caD1a5302755d7A2
#OPERATOR_REGISTRY_FUJI=

# Operator L1 Opt-In contract address on Fuji
# Default: 0x0360C1cB32A20D97b358538D9Db71339ce2c9592
#OP_L1_OPT_IN_FUJI=

# Operator Vault Opt-In contract address on Fuji
# Default: 0xC30c9f7482B2ED82d0532812285295f8b7453941
#OP_VAULT_OPT_IN_FUJI=

# ==============================================================================
# CONTRACT ADDRESSES - LOCAL DEVELOPMENT
# ==============================================================================

# L1 Registry contract address for local development
# Default: 0x0165878A594ca255338adfa4d48449f69242Eb8F
