{
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6"
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": ["tg:${TELEGRAM_ADMIN_USER_ID}"],
      "groupPolicy": "allowlist",
      "groups": {
        "${TELEGRAM_GROUP_ID}": {
          "requireMention": true
        }
      }
    }
  },
  "skills": {
    "entries": {
      "mcporter": {
        "enabled": true
      }
    }
  }
}
