{
  "mcpServers": {
    "suzaku": {
      "description": "Suzaku propose-only profile: all reads + the two Safe rewards propose tools",
      "command": "node",
      "args": ["/mcp/packages/mcp/dist/server.js", "--propose-only"],
      "env": {
        "SUZAKU_CLI_PATH": "/mcp/bin/cli.js",
        "SUZAKU_PK": "${SUZAKU_PK}",
        "SUZAKU_SAFE_ADDRESS": "${SUZAKU_SAFE_ADDRESS}",
        "SAFE_API_KEY": "${SAFE_API_KEY}",
        "ALLOW_SAFE_DELEGATE_MAINNET": "true",
        "SUZAKU_REWARDS_ADDRESS": "${SUZAKU_REWARDS_ADDRESS}",
        "SUZAKU_MIDDLEWARE_ADDRESS": "${SUZAKU_MIDDLEWARE_ADDRESS}",
        "SUZAKU_MAX_REWARDS_AMOUNT": "${SUZAKU_MAX_REWARDS_AMOUNT}",
        "SUZAKU_MCP_DEDUP_WINDOW_MS": "30000",
        "SUZAKU_MCP_MAX_CONCURRENT": "8",
        "SUZAKU_MCP_RATE_MAX_CALLS": "30",
        "SUZAKU_MCP_RATE_WINDOW_MS": "60000",
        "SUZAKU_MCP_AUDIT_MAX_MB": "50",
        "SUZAKU_MCP_AUDIT_DIR": "/data/audit"
      }
    }
  }
}
