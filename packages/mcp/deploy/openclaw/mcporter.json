{
  "mcpServers": {
    "suzaku": {
      "description": "Suzaku restaking protocol tools (read-only)",
      "command": "node",
      "args": ["/mcp/packages/mcp/dist/server.js", "--read-only"],
      "env": {
        "SUZAKU_CLI_PATH": "/mcp/bin/cli.js",
        "SUZAKU_MCP_DEDUP_WINDOW_MS": "30000",
        "SUZAKU_MCP_PUBLIC_HEALTH": "true",
        "SUZAKU_MCP_MAX_CONCURRENT": "8",
        "SUZAKU_MCP_RATE_MAX_CALLS": "60",
        "SUZAKU_MCP_RATE_WINDOW_MS": "60000",
        "SUZAKU_MCP_AUDIT_MAX_MB": "50",
        "SUZAKU_MCP_AUDIT_DIR": "/data/audit"
      }
    }
  }
}
