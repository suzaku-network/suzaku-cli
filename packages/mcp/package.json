{
  "name": "@suzaku-network/mcp",
  "version": "0.1.0",
  "description": "MCP server for suzaku-cli — exposes Avalanche L1/restaking operations as AI tools",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "main": "dist/server.js",
  "bin": {
    "suzaku-mcp": "dist/server.js"
  },
  "files": [
    "dist"
  ],
  "mcpName": "io.github.suzaku-network/mcp",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "avalanche",
    "restaking",
    "suzaku",
    "claude",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/suzaku-network/suzaku-cli",
    "directory": "packages/mcp"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/server.js",
    "prepublishOnly": "pnpm build",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.12.0",
    "suzaku-cli": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "@types/node": "^24.0.0"
  }
}
