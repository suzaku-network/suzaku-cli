{
  "name": "@suzaku-network/suzaku-cli",
  "version": "1.0.4",
  "homepage": "https://github.com/suzaku-network/suzaku-cli?tab=readme-ov-file#suzaku-cli",
  "license": "ADDPHO",
  "keywords": [
    "Avalanche",
    "blockchain",
    "defi",
    "suzaku",
    "staking",
    "restaking"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/suzaku-network/suzaku-cli.git"
  },
  "files": [
    "dist",
    "bin",
    "defaults",
    "env.template",
    "env.fuji.template"
  ],
  "scripts": {
    "suzaku-cli": "node dist/cli.js",
    "cli": "pnpx tsx src/cli.ts",
    "build": "tsup",
    "prepare": "pnpm build",
    "typecheck": "tsc --noEmit",
    "add-shell-completion": "pnpm link && suzaku-cli completion install"
  },
  "bin": {
    "suzaku-cli": "bin/cli.js"
  },
  "dependencies": {
    "@avalanche-sdk/client": "0.1.1",
    "@avalabs/avalanchejs": "^5.1.0-alpha.1",
    "@avalabs/hw-app-avalanche": "1.1.1",
    "@commander-js/extra-typings": "^14.0.0",
    "@ledgerhq/hw-app-eth": "7.1.1",
    "@ledgerhq/hw-transport-node-hid": "6.29.16",
    "@mobily/ts-belt": "^3.13.1",
    "@noble/hashes": "1.8.0",
    "@safe-global/sdk-starter-kit": "4.0.0",
    "@scure/base": "1.2.6",
    "@suzaku-network/suzaku-sdk": "workspace:*",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.0",
    "console-log-colors": "^0.5.0",
    "dotenv": "16.6.1",
    "micro-eth-signer": "0.7.2",
    "modern-ahocorasick": "^2.0.4",
    "permissionless": "0.3.2",
    "viem": "2.49.2"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "24.10.1",
    "typescript": "5.9.3"
  }
}
