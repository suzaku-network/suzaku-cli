{
  "name": "@suzaku-network/sdk",
  "version": "0.37.0",
  "description": "Browser-safe SDK for Suzaku KiteStaking operations on Avalanche",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "viem": ">=2.0.0",
    "@avalabs/avalanchejs": ">=5.0.0"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "@scure/base": "^1.2.6"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "viem": "2.40.3",
    "@avalabs/avalanchejs": "5.0.0"
  },
  "keywords": [
    "avalanche",
    "suzaku",
    "staking",
    "kite",
    "sdk",
    "blockchain"
  ],
  "license": "MIT"
}
